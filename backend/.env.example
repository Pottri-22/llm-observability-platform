# Backend env. Copy to .env when running uv outside docker.
# When running via docker-compose, the API container reads env from compose's environment block.

# Postgres (async DSN — note +asyncpg driver)
POSTGRES_DSN=postgresql+asyncpg://aegis:aegis_dev_pw@localhost:5432/aegis

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=aegis
CLICKHOUSE_PASSWORD=aegis_dev_pw
CLICKHOUSE_DATABASE=aegis

# Redis (idempotency + future eval queue)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Environment label (dev | staging | prod)
ENV=dev

# JWT signing secret (placeholder; only used once dashboard auth lands in v0.2)
AEGIS_JWT_SECRET=replace_me_with_a_long_random_string
